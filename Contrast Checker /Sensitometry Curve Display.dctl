// Sensitometry Curve - Display
// Place this on the LAST node after any LUTs / grades you want to inspect.
// Reads the strip generated by Sensitometry Curve Probe.dctl and renders the
// classic Kodak H&D characteristic curve.
//
// Default: Y = density, top X = log exposure (decades), bottom X = camera stops,
// with isotropic 1:1 scaling between density and log exposure decades.
//
// Other Y axes (Output %, Linear Output) and X axes (Stops, Linear) are also
// available; clamping and the log-exposure offset work in every combination.

#define X_MODE_STOPS 0
#define X_MODE_LOG_EXPOSURE 1

#define Y_MODE_PERCENT 0
#define Y_MODE_DENSITY 1
#define Y_MODE_LINEAR 2

#define LAYOUT_FULLSCREEN 0
#define LAYOUT_BOTTOM 1
#define LAYOUT_RIGHT 2

#define PROBE_STOP_MIN -8.0f
#define PROBE_STOP_MAX 8.0f
#define PROBE_MID_GRAY 0.18f
#define PROBE_SAMPLE_ROW_OFFSET 0
#define PROBE_PRESENCE_THRESHOLD 0.05f

#define LOG10_2 0.3010299957f
#define DENSITY_EPS 1.0e-5f
#define CLAMP_THRESHOLD 0.02f
#define CLAMP_SCAN_N 64

// clang-format off
DEFINE_UI_PARAMS(x_mode, X Axis, DCTLUI_COMBO_BOX, 1, {X_MODE_STOPS, X_MODE_LOG_EXPOSURE}, {Stops, Log Exposure})
DEFINE_UI_PARAMS(y_mode, Y Axis, DCTLUI_COMBO_BOX, 1, {Y_MODE_PERCENT, Y_MODE_DENSITY}, {Output %, Density})
DEFINE_UI_PARAMS(layout, Chart Layout, DCTLUI_COMBO_BOX, 1, {LAYOUT_FULLSCREEN, LAYOUT_BOTTOM, LAYOUT_RIGHT}, {Fullscreen, Bottom Overlay, Right Overlay})
DEFINE_UI_PARAMS(overlay_size_pct, Overlay Size %, DCTLUI_SLIDER_FLOAT, 50.0, 10.0, 100.0, 1.0)
DEFINE_UI_PARAMS(clamp_result, Clamp to Active Range, DCTLUI_CHECK_BOX, 1)
DEFINE_UI_PARAMS(offset_to_zero, Offset Log Exposure to 0, DCTLUI_CHECK_BOX, 0)
DEFINE_UI_PARAMS(transparent_bg, Transparent Background, DCTLUI_CHECK_BOX, 0)
// clang-format on

